<?xml version="1.0" encoding="utf-8" ?>
<!--
  Web 的診斷 log（與批次 exe 的 logs\logforesight.log 分開，各自的執行脈絡不同）。
  容量控制沿用批次端的策略：單檔 10MB 輪替、最多保留 30 個歸檔。
-->
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      internalLogToConsole="true"
      internalLogLevel="Warn">

    <extensions>
        <add assembly="NLog.Web.AspNetCore" />
    </extensions>

    <targets>
        <target xsi:type="File" name="webfile"
                fileName="${basedir}/logs/web.log"
                archiveFileName="${basedir}/logs/archive/web.{#}.log"
                archiveNumbering="Rolling"
                archiveAboveSize="10485760"
                maxArchiveFiles="30"
                encoding="utf-8"
                layout="${longdate}|${level:uppercase=true}|${logger:shortName=true}|${aspnet-user-identity}|${message}${onexception:${newline}${exception:format=ToString}}" />

        <target xsi:type="Console" name="console"
                layout="${time}|${level:uppercase=true}|${message}${onexception: ${exception:format=Message}}" />
    </targets>

    <rules>
        <!-- 框架自身的 Info 訊息量大且對排查沒有幫助，只留 Warn 以上 -->
        <logger name="Microsoft.*" maxlevel="Info" final="true" />
        <logger name="System.Net.Http.*" maxlevel="Info" final="true" />

        <logger name="*" minlevel="Info" writeTo="webfile" />
        <logger name="*" minlevel="Info" writeTo="console" />
    </rules>
</nlog>
