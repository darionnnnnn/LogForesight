@{
    ViewData["Title"] = "問題查詢";
}

<div class="lf-toolbar lf-no-print">
    <form id="filter-form" class="lf-toolbar__row">
        <div class="lf-toolbar__field position-relative" style="min-width: 240px;">
            <label for="filter-host-search" class="form-label small mb-1">主機</label>
            <input type="text" class="form-control form-control-sm" id="filter-host-search"
                   placeholder="輸入主機名稱搜尋…" autocomplete="off" />
            <div id="filter-host-suggestions" class="dropdown-menu p-0" style="max-height: 260px; overflow-y: auto;"></div>
            <div id="filter-host-chips" class="d-flex flex-wrap gap-1 mt-1"></div>
        </div>
        <div class="lf-toolbar__field" style="min-width: 150px;">
            <label for="filter-from" class="form-label small mb-1">起始日期</label>
            <input type="date" class="form-control form-control-sm" id="filter-from" />
        </div>
        <div class="lf-toolbar__field" style="min-width: 150px;">
            <label for="filter-to" class="form-label small mb-1">結束日期</label>
            <input type="date" class="form-control form-control-sm" id="filter-to" />
        </div>
        <div class="lf-toolbar__field" style="min-width: 100px;">
            <label for="filter-event-id" class="form-label small mb-1">Event ID</label>
            <input type="number" class="form-control form-control-sm" id="filter-event-id" />
        </div>
        <div class="d-flex gap-2 align-self-end">
            <button type="submit" class="btn btn-sm btn-primary">套用</button>
            <button type="button" class="btn btn-sm btn-outline-secondary" id="btn-reset">清除條件</button>
        </div>

        <div class="lf-toolbar__spacer"></div>

        <div class="lf-toolbar__group align-self-end">
            <span class="lf-toolbar__group-label">期間快捷</span>
            <div class="lf-toolbar__chips">
                <button type="button" class="lf-chip" data-range="7">近 7 天</button>
                <button type="button" class="lf-chip" data-range="30">近 30 天</button>
                <button type="button" class="lf-chip" data-range="90">近 90 天</button>
            </div>
        </div>
    </form>

    <div class="lf-toolbar__row">
        <div class="lf-toolbar__group">
            <span class="lf-toolbar__group-label">風險層級</span>
            <div class="lf-toolbar__chips" id="filter-risk-chips">
                <button type="button" class="lf-chip" data-risk="高">高</button>
                <button type="button" class="lf-chip" data-risk="中">中</button>
                <button type="button" class="lf-chip" data-risk="低">低</button>
            </div>
        </div>
        <div class="lf-toolbar__divider"></div>
        <div class="lf-toolbar__group">
            <span class="lf-toolbar__group-label">風險類型</span>
            <div class="lf-toolbar__chips" id="filter-category-chips">
                <button type="button" class="lf-chip" data-category="Storage">儲存裝置</button>
                <button type="button" class="lf-chip" data-category="Hardware">硬體</button>
                <button type="button" class="lf-chip" data-category="Security">安全</button>
                <button type="button" class="lf-chip" data-category="Service">服務</button>
                <button type="button" class="lf-chip" data-category="Backup">備份</button>
                <button type="button" class="lf-chip" data-category="Config">設定</button>
                <button type="button" class="lf-chip" data-category="Resource">資源</button>
                <button type="button" class="lf-chip" data-category="Other">其他</button>
            </div>
        </div>
        <div class="lf-toolbar__divider"></div>
        <div class="lf-toolbar__group">
            <span class="lf-toolbar__group-label">處理狀態</span>
            <div class="lf-toolbar__chips" id="filter-status-chips">
                <button type="button" class="lf-chip" data-status="open">未處理</button>
                <button type="button" class="lf-chip" data-status="in_progress">處理中</button>
                <button type="button" class="lf-chip" data-status="resolved">已處理</button>
            </div>
        </div>
    </div>

    <div class="lf-toolbar__row" id="filter-group-row">
        <div class="lf-toolbar__group">
            <span class="lf-toolbar__group-label">主機群組</span>
            <div class="lf-toolbar__chips" id="filter-group-chips"></div>
        </div>
    </div>

    <div class="lf-toolbar__row" id="active-conditions"></div>
</div>

<div class="lf-card">
    <div class="lf-card__header">
        <div class="d-flex align-items-center gap-3">
            <div class="btn-group btn-group-sm lf-no-print" role="group" aria-label="檢視角度" id="view-toggle">
                <button type="button" class="btn btn-outline-primary" data-view="detail">明細</button>
                <button type="button" class="btn btn-outline-primary" data-view="host">依主機</button>
                <button type="button" class="btn btn-outline-primary" data-view="date">依日期</button>
            </div>
            <span class="text-muted small" id="result-count"></span>
        </div>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-sm btn-outline-secondary lf-no-print d-none" id="btn-ai-summary">AI 歸納</button>
            <button type="button" class="btn btn-sm btn-outline-secondary lf-no-print" id="btn-copy-csv">複製為 CSV</button>
        </div>
    </div>
    <div id="ai-summary" class="px-3 pt-3"></div>
    <div class="lf-card__body p-0" id="record-list"></div>
</div>

<nav class="mt-3 lf-no-print" id="pager"></nav>

@section Scripts {
    <script type="module" src="~/js/pages/records.js" asp-append-version="true"></script>
}
