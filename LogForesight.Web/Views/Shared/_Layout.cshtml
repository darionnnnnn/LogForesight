@*
    主版面（docs/WEB-SPEC.md §8.2 版面骨架、§8.5 頁面殼）。
    View 只有結構、沒有資料——側欄選單由 core/layout.js 依 /api/auth/me 回傳的能力渲染。
*@
<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LogForesight</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="lf-layout">
        <aside class="lf-sidebar lf-no-print">
            <div class="lf-sidebar__brand">
                <span class="lf-sidebar__brand-mark">
                    <svg class="lf-icon" aria-hidden="true"><use href="/img/icons.svg#speedometer2"></use></svg>
                </span>
                <span>
                    LogForesight
                    <small>Windows 事件日誌預警</small>
                </span>
            </div>
            <nav class="lf-sidebar__nav" id="lf-nav"></nav>
            <div class="lf-sidebar__footer">
                <div class="lf-sidebar__user">
                    <svg class="lf-icon" aria-hidden="true"><use href="/img/icons.svg#people"></use></svg>
                    <span id="lf-current-user" class="text-truncate"></span>
                </div>
                <button type="button" class="btn btn-sm btn-outline-light w-100" id="lf-logout">
                    <svg class="lf-icon" aria-hidden="true"><use href="/img/icons.svg#box-arrow-right"></use></svg>
                    登出
                </button>
            </div>
        </aside>

        <div class="lf-main">
            <header class="lf-topbar lf-no-print">
                <h1 class="lf-topbar__title">@ViewData["Title"]</h1>
                <div class="btn-group btn-group-sm" role="group" aria-label="字級" id="lf-font-scale">
                    <button type="button" class="btn btn-outline-secondary" data-scale="small" title="小字級">小</button>
                    <button type="button" class="btn btn-outline-secondary" data-scale="medium" title="標準字級">中</button>
                    <button type="button" class="btn btn-outline-secondary" data-scale="large" title="大字級">大</button>
                </div>
            </header>

            <main class="lf-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" asp-append-version="true"></script>
    <script type="module" src="~/js/core/layout.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
