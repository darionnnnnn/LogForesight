@*
    主版面（docs/WEB-SPEC.md §8.2 版面骨架、§8.5 頁面殼）。
    View 只有結構、沒有資料——側欄選單由 core/layout.js 依 /api/auth/me 回傳的能力渲染。
*@
<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LogForesight</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="lf-layout">
        <aside class="lf-sidebar lf-no-print">
            <div class="lf-sidebar__brand">
                LogForesight
                <small>Windows 事件日誌預警</small>
            </div>
            <nav class="lf-sidebar__nav" id="lf-nav"></nav>
            <div class="lf-sidebar__footer">
                <div id="lf-current-user" class="mb-2 text-truncate"></div>
                <button type="button" class="btn btn-sm btn-outline-light w-100" id="lf-logout">登出</button>
            </div>
        </aside>

        <div class="lf-main">
            <header class="lf-topbar lf-no-print">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item active" aria-current="page">@ViewData["Title"]</li>
                    </ol>
                </nav>
            </header>

            <main class="lf-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script type="module" src="~/js/core/layout.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
