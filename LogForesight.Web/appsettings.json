{
  // ════════════════════════════════════════════════════════════════════════════
  //  LogForesight.Web 設定
  //
  //  ★ 本檔已內含「開箱即可登入」的測試預設值——用 IIS Express / `dotnet run` 啟動
  //    （會以 Development 環境執行）即可直接登入:
  //        帳號:svc-lfadmin
  //        密碼:LogForesight-dev
  //    （svc-lfadmin 是本地救援管理員;Provider=Stub 時一般帳號免密碼登入。）
  //
  //  ★★★【正式環境務必修改，以下為已知的測試值，切勿沿用】★★★
  //    這個檔會進版控與 GitHub,SecretKey / PasswordHash 是「公開已知」的測試值。
  //    部署到真實伺服器前務必:
  //      1. Auth:Provider 改成 "Ldap"（Stub 不驗密碼;正式環境用 Stub 啟動時會被直接擋下）。
  //      2. 以環境變數覆寫機密（不要把真實金鑰寫回本檔）:
  //           Jwt__SecretKey                     ← 另外產生的 ≥32 bytes 隨機字串
  //           Auth__ServerAdmin__PasswordHash    ← LogForesight.Web.exe --hash-password 產生
  //      3. Storage:DataRoot 指向批次 LogForesight.exe 的執行檔目錄。
  //      4. Auth:Ldap:Domain 填入 AD 網域名稱。
  //  （本檔支援 // 註解與尾逗號。存檔請用 UTF-8。）
  // ════════════════════════════════════════════════════════════════════════════

  "Storage": {
    // DataRoot 指向批次 LogForesight.exe 的執行檔目錄（history.txt / rules.json / webdata 所在）。
    // 空字串＝本站台自己的執行檔目錄（測試可直接啟動;正式環境務必明確指向批次目錄才讀得到同一份資料）。
    // 本機開發若要讀批次的實際資料,在 appsettings.Development.json 覆寫這個路徑。
    "Type": "Jsonl",
    "DataRoot": "",
    "ConnectionString": ""
  },

  "Jwt": {
    "Issuer": "LogForesight",
    "Audience": "LogForesight.Web",
    // 【正式環境需修改】HMAC-SHA256 簽章金鑰（≥32 bytes）。
    // 下面這組是「公開已知」的測試值,僅供本機測試——正式環境用環境變數 Jwt__SecretKey 覆寫。
    "SecretKey": "bge6V8SsJu6GRuYYyVniemo/XhAJ4J3kis3sqSDai5gluW9wmA2Vnd4opTbXBTxo",
    "ExpireHours": 8,
    "CookieName": "lf_auth"
  },

  "Auth": {
    // 驗證方式:Stub（測試,不驗密碼）或 Ldap（AD 帳密）。
    // 【正式環境需修改】改成 "Ldap"——正式環境用 Stub 啟動時會被擋下。
    "Provider": "Stub",
    "ServerAdmin": {
      // 本地救援帳號:指派 admin 成員、AD 停擺時的入口。
      "Account": "svc-lfadmin",
      // 【正式環境需修改】PBKDF2 雜湊,以 LogForesight.Web.exe --hash-password 產生。
      // 下面這組對應明文密碼 = LogForesight-dev（公開已知的測試值,僅供本機測試）;
      // 正式環境用環境變數 Auth__ServerAdmin__PasswordHash 覆寫。
      "PasswordHash": "PBKDF2$210000$s79Mzbz0FKaArA2SsMlCuQ==$2JKMIZGXFQbelisLIZZo+WAMCPJ0Ao3XPm5jg8TFy9M=",
      "MaxFailedAttempts": 5,
      "LockoutMinutes": 15
    },
    "Ldap": {
      // 【正式環境需修改】Provider=Ldap 時必填 AD 網域名稱,如 corp.local。
      "Domain": ""
    }
  },

  "Import": {
    "MaxFileSizeKb": 2048,
    "MaxRows": 5000
  },

  "Ui": {
    "DefaultPageSize": 50,
    "DashboardDefaultDays": 7,
    "RunMatrixDays": 14
  },

  "AllowedHosts": "*"
}
