<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Off">

  <!--
    診斷用檔案 log，補足 console 訊息不夠細的問題（重試原因、AI 回應內容的短預覽、
    未預期例外的完整堆疊等）。原則：只寫統計數字與短診斷片段，不寫完整 prompt 或
    完整 Event Log 內容——避免 log 檔案隨著資料量或執行次數無限膨脹。

    容量控制雙重防護：
    1. 單檔超過 10MB 就輪替（archiveAboveSize）
    2. 最多保留 30 個歸檔檔案，超過自動刪除最舊的（maxArchiveFiles）
    即使程式邏輯不慎寫入過大內容，磁碟用量仍有上限，不會無限增長。
  -->
  <!--
    logDir 預設用 NLog 自己的 ${basedir}，但實際目錄一律由 Program.cs 在啟動時明確覆寫成
    AppContext.BaseDirectory（跟 history.txt/export/appsettings.json 用同一套基準邏輯），
    不同啟動方式（捷徑、排程工作、工作目錄不同）造成 ${basedir} 判斷跟執行檔目錄兜不上的
    問題就不會發生。這裡的 value 只是程式覆寫失敗時的備援。
  -->
  <variable name="logDir" value="${basedir}/logs" />

  <targets>
    <target name="file" xsi:type="File"
            fileName="${var:logDir}/logforesight.log"
            archiveFileName="${var:logDir}/archive/logforesight.{#}.log"
            archiveAboveSize="10485760"
            archiveNumbering="Rolling"
            maxArchiveFiles="30"
            concurrentWrites="true"
            keepFileOpen="false"
            encoding="utf-8"
            layout="${longdate} [${level:uppercase=true:padding=-5}] ${logger:shortName=true} - ${message}${onexception:${newline}${exception:format=tostring}}" />
  </targets>

  <rules>
    <!-- Info 以上進檔案：關鍵流程節點、統計數字、失敗原因、例外堆疊。Debug 用於更細的診斷，預設關閉 -->
    <logger name="*" minlevel="Info" writeTo="file" />
  </rules>
</nlog>
